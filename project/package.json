{
  "name": "exam-flash-sales-system",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:code-gen": "pnpm -r --parallel --if-present run \"/^generate:[A-Za-z]+$/\"",
    "dev:code-gen:watch": "pnpm -r --parallel --if-present run \"/^generate:[A-Za-z]+:watch$/\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test:unit": "pnpm -r --sequential test:unit",
    "test:integration": "pnpm -r --sequential test:integration",
    "test:coverage": "pnpm -r --sequential test:coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.0"
  }
}
