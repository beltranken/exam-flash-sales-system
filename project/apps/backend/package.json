{
  "name": "@apps/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-lua-scripts.mjs",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests --testPathIgnorePatterns=\\.integration\\.test\\.ts$",
    "test:integration": "jest --passWithNoTests --testPathPattern=\\.integration\\.test\\.ts$",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "generate:spec": "tsx ./src/scripts/generate-spec.ts",
    "generate:spec:watch": "tsx watch ./src/scripts/generate-spec.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@shared/db": "workspace:*",
    "@shared/logger": "workspace:*",
    "@shared/order-events": "workspace:*",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "http-errors": "^2.0.1",
    "ms": "^2.1.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^29.5.14",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
